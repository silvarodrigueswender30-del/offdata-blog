---
// src/layouts/BaseLayout.astro
// Layout base mínimo do blog Off-Data.
// Responsabilidade: estrutura HTML invariante + globals.css.
// Cada página injeta seu próprio <head> via <slot name="head" />.
// Header e Footer serão adicionados nos próximos prompts.
import '../styles/globals.css';
import { withBase } from '../utils/withBase';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase("/isologoazul.svg")} />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <FloatingWhatsApp />
  </body>
</html>
