---
/**
 * src/components/Header.astro
 * Estrutura e estilos estáticos fiéis ao REPORT-001-header-footer.md.
 *
 * Não implementado neste arquivo (vem no próximo prompt como <script>):
 *  - Toggle do menu mobile (is-open)
 *  - Detecção de scroll (is-scrolled)
 *  - Detecção de is-light-section / troca de logo
 *  - Animação line-reveal
 */

const WHATSAPP_NUMBER = '5534992362596';
const WHATSAPP_MSG    = encodeURIComponent(
  'Olá, vim pelo blog da Off-Data e quero falar com a equipe.'
);
const WHATSAPP_URL    = `https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MSG}`;

const navLinks = [
  { label: 'Início',      href: '/#home'             },
  { label: 'Serviços',    href: '/#products'          },
  { label: 'Nichos',      href: '/#built-for'         },
  { label: 'Estratégias', href: '/#strategies-title'  },
  { label: 'Blog',        href: '/blog'               },
];

const rightLinks = [
  { label: 'Cases', href: '/#cutting-edge' },
  { label: 'Sobre',  href: '/agencia'       },
];

const mobileLinks = [
  { label: 'Início',   href: '/#home'            },
  { label: 'Serviços', href: '/#products'         },
  { label: 'Sobre',    href: '/agencia'            },
  { label: 'Nichos',   href: '/#built-for'         },
  { label: 'Cases',    href: '/#cutting-edge'      },
  { label: 'Contato',  href: WHATSAPP_URL, external: true },
];
---

<header class="header" id="site-header">
  <div class="wrapper_header">
    <div class="flexbox_header">

      <!-- ── Logo ─────────────────────────────────────────────── -->
      <div class="logo_box">
        <a href="https://offdata.com.br/" aria-label="Off-Data" class="logotype w-inline-block">
          <!-- data-logo permite ao JS trocar src em is-light-section -->
          <img
            src="/images/logo-branca.svg"
            alt="Off-Data Engenharia Digital"
            width="1651"
            height="238"
            decoding="async"
            fetchpriority="high"
            class="svg_logo"
            data-logo-white="/images/logo-branca.svg"
            data-logo-blue="/images/logo-azul.svg"
          />
        </a>
      </div>

      <!-- ── Menu central — cápsula blur ──────────────────────── -->
      <nav class="menu" aria-label="Menu principal">
        {navLinks.map(({ label, href }) => (
          <a data-line-reveal href={href} class="link_header w-inline-block">
            <div>{label}</div>
          </a>
        ))}
      </nav>

      <!-- ── Right menu — cápsula blur + CTA ──────────────────── -->
      <div class="right_menu">
        {rightLinks.map(({ label, href }) => (
          <a data-line-reveal href={href} class="link_header w-inline-block">
            <div>{label}</div>
          </a>
        ))}

        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="button_primary w-inline-block"
          aria-label="Entre em contato via WhatsApp"
        >
          <div class="flex_button">
            <div class="text_header">Entre em contato</div>
            <div class="icon_arrow">
              <img
                src="/images/arrow-diagonal.svg"
                alt=""
                aria-hidden="true"
                width="14"
                height="14"
                class="arrow_primary"
              />
            </div>
          </div>
        </a>
      </div>

      <!-- ── Hamburger (mobile / tablet) ───────────────────────── -->
      <button
        type="button"
        class="hamburger_link"
        id="hamburger-btn"
        aria-label="Abrir menu de navegação"
        aria-expanded="false"
        aria-controls="mobile-navigation"
      >
        <div class="close_txt" aria-hidden="true">Fechar</div>
        <div class="open_txt"  aria-hidden="true">Menu</div>
        <div class="hamburger" aria-hidden="true">
          <div class="cube_hamb"></div>
          <div class="cube_hamb"></div>
          <div class="cube_hamb middle_cube"></div>
          <div class="cube_hamb"></div>
          <div class="cube_hamb"></div>
        </div>
      </button>

    </div>
  </div>

  <!-- ── Mobile Menu ───────────────────────────────────────────── -->
  <nav id="mobile-navigation" class="mobile_menu" aria-hidden="true" aria-label="Menu mobile">
    <div class="wrapper_mobile_menu">
      <div class="menu_links">
        {mobileLinks.map(({ label, href, external }) => (
          <a
            href={href}
            class="mobile_link w-inline-block"
            {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <div class="cube_active"></div>
            <div>{label}</div>
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<style>
  /* ═══════════════════════════════════════════════════════════════════
     HEADER OFF-DATA — Estilos estáticos
     Fonte de verdade: REPORT-001-header-footer.md, seções 2, 3 e 4.
     Todas as cores via variáveis de globals.css.
     ═══════════════════════════════════════════════════════════════════ */

  /* ── Posicionamento base ── */
  .header {
    z-index: 99;
    position: fixed;
    inset: 0% 0% auto;
  }

  .wrapper_header {
    padding: .875em 1.75rem;
    position: relative;
    z-index: 2;
  }

  /* ── Grid 3 colunas (logo | nav central | nav direita) ── */
  .flexbox_header {
    grid-column-gap: 0;
    grid-row-gap: 0;
    grid-template-rows: auto;
    grid-template-columns: 1fr 1fr 1fr;
    grid-auto-columns: 1fr;
    justify-content: flex-start;
    place-items: stretch start;
    display: grid;
  }

  /* ── Logo ── */
  .logo_box {
    justify-content: flex-start;
    align-items: center;
    display: flex;
  }

  .logotype {
    width: 9em;
    height: 2em;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    transition: opacity 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .logotype:hover {
    opacity: 0.7;
  }

  .svg_logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* ── Menu central — cápsula blur ── */
  .menu {
    grid-column-gap: .25em;
    -webkit-backdrop-filter: blur(7px);
    backdrop-filter: blur(7px);
    background-color: var(--glass-bg);
    border-radius: .25em;
    justify-content: flex-start;
    align-items: stretch;
    margin-left: 0;
    padding: .25em;
    display: flex;
    transition: background-color 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ── Links do header ── */
  /* Tipografia: REPORT-001 § 2 — .link_header */
  .link_header {
    color: var(--white);
    letter-spacing: 0;
    justify-content: center;
    align-items: center;
    padding: .75em 1.125em;
    font-size: .84em;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    transition: all .4s;
    display: flex;
  }

  /* Estado ativo (página atual) */
  .link_header.w--current {
    background-color: var(--white);
    color: var(--blue);
    border-radius: .18em;
  }

  /* ── Right menu — cápsula blur ── */
  .right_menu {
    grid-column-gap: .25em;
    -webkit-backdrop-filter: blur(7px);
    backdrop-filter: blur(7px);
    background-color: var(--glass-bg);
    border-radius: .25em;
    justify-content: flex-start;
    align-items: stretch;
    margin-left: auto;
    padding: .25em .375em .25em .25em;
    display: flex;
    transition: background-color 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ── Botão CTA ── */
  /* Tipografia: REPORT-001 § 2 — .button_primary */
  .button_primary {
    background-color: var(--white);
    height: auto;
    color: var(--blue);
    letter-spacing: -.02em;
    border-radius: .1875em;
    justify-content: flex-start;
    align-items: stretch;
    padding: .25em .25em .25em .75em;
    font-size: .82em;
    font-weight: 500;
    line-height: inherit;
    text-decoration: none;
    display: flex;
    cursor: pointer;
    transition: opacity 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .button_primary:hover {
    opacity: 0.9;
  }

  .flex_button {
    grid-column-gap: 1.125em;
    letter-spacing: 0;
    justify-content: flex-start;
    align-items: stretch;
    display: flex;
  }

  .text_header {
    margin-top: auto;
    margin-bottom: auto;
    white-space: nowrap;
  }

  /* ── Ícone seta (quadrado azul) ── */
  .icon_arrow {
    aspect-ratio: 1;
    background-color: var(--blue);
    border-radius: .1875em;
    justify-content: center;
    align-items: center;
    width: 1.875em;
    height: 1.875em;
    padding: .5em;
    display: flex;
    overflow: hidden;
  }

  .arrow_primary {
    width: 14px;
    height: 14px;
    object-fit: contain;
  }

  /* ── Hamburger ── */
  .hamburger_link {
    display: none;
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0;
    font: inherit;
    cursor: pointer;
  }

  .hamburger {
    display: none;
  }

  .cube_hamb {
    background-color: var(--white);
    border-radius: .5px;
    width: 8px;
    height: 8px;
  }

  /* ── Textos do hamburger ── */
  /* Tipografia: REPORT-001 § 2 — .close_txt / .open_txt */
  .close_txt {
    display: none;
    font-size: 0.9em;
    color: var(--white);
    line-height: inherit;
  }

  .open_txt {
    font-size: 0.9em;
    color: var(--white);
    line-height: inherit;
  }

  /* ── Mobile menu (fechado por padrão) ── */
  .mobile_menu {
    position: fixed;
    inset: 0;
    z-index: 98;
    background-color: var(--blue);
    display: none;          /* JS adicionará .is-open para exibir */
    flex-direction: column;
    padding: 6em 1.75rem 2rem;
    overflow-y: auto;
  }

  /* Estado aberto — ativado pelo script no próximo prompt */
  .mobile_menu.is-open {
    display: flex;
  }

  .wrapper_mobile_menu {
    display: flex;
    flex-direction: column;
    gap: 2em;
  }

  .menu_links {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  /* Tipografia: REPORT-001 § 2 — .mobile_link */
  .mobile_link {
    color: var(--white);
    text-decoration: none;
    font-size: 1.6em;
    font-weight: 500;
    line-height: inherit;
    position: relative;
    display: inline-flex;
    align-items: center;
    padding-left: 0;
    transition: padding-left .25s ease;
  }

  /* Cubo indicador de item ativo */
  .cube_active {
    position: absolute;
    left: 0;
    top: 50%;
    width: 8px;
    height: 8px;
    background-color: var(--white);
    transform: translateY(-50%) scale(.7);
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease, transform .25s ease;
  }

  .mobile_link.w--current {
    padding-left: 20px;
  }

  .mobile_link.w--current .cube_active {
    opacity: 1;
    transform: translateY(-50%) scale(1);
  }

  /* ── Transição de logo (is-light-section — via JS) ── */
  .header .svg_logo {
    transition: opacity 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Quando sobre seção clara: cápsulas ficam azul sólido */
  :global(.header.is-light-section) .menu,
  :global(.header.is-light-section) .right_menu {
    background: var(--blue);
  }

  /* ═══════════════════════════════════════════════════════════════════
     RESPONSIVO — 991px (tablet: hamburger entra)
     REPORT-001 § 3: wrapper_header → 1rem 1.2rem
     ═══════════════════════════════════════════════════════════════════ */
  @media screen and (max-width: 990px) {
    .header {
      background-color: var(--blue);
    }

    .wrapper_header {
      padding: 1rem 1.2rem;
    }

    .flexbox_header {
      display: flex;
    }

    .logotype {
      width: 16em;
      height: 2.8em;
    }

    /* Oculta cápsulas desktop */
    .menu,
    .right_menu {
      display: none;
    }

    /* Exibe hamburger */
    .hamburger {
      grid-column-gap: 0;
      grid-row-gap: 0;
      grid-template-rows: auto auto;
      grid-template-columns: 1fr 1fr;
      grid-auto-columns: 1fr;
      place-items: center;
      width: 32px;
      height: 32px;
      display: grid;
      position: relative;
    }

    .cube_hamb {
      background-color: var(--white);
      border-radius: .5px;
      width: 8px;
      height: 8px;
    }

    .cube_hamb.middle_cube {
      margin: auto;
      position: absolute;
      inset: 0%;
      transform: scale(0);
    }

    .hamburger_link {
      grid-column-gap: 12px;
      justify-content: flex-start;
      align-items: center;
      margin-left: auto;
      font-size: 1.85em;
      display: flex;
    }

    .close_txt {
      display: none;
    }

    /* Estados aberto — JS adiciona .is-open ao button */
    .hamburger_link.is-open .close_txt {
      display: block;
    }

    .hamburger_link.is-open .open_txt {
      display: none;
    }
  }

  /* ═══════════════════════════════════════════════════════════════════
     RESPONSIVO — 767px (mobile)
     REPORT-001 § 3: wrapper_header → 0.8rem 1rem
     ═══════════════════════════════════════════════════════════════════ */
  @media screen and (max-width: 767px) {
    .wrapper_header {
      padding: 0.8rem 1rem;
    }

    .logotype {
      width: 8.35em;
      height: 1.5em;
    }

    .hamburger_link {
      grid-column-gap: 10px;
      font-size: 1em;
    }

    .hamburger {
      width: 24px;
      height: 24px;
    }

    .cube_hamb {
      width: 6px;
      height: 6px;
    }
  }

  /* ═══════════════════════════════════════════════════════════════════
     RESPONSIVO — 479px (small mobile)
     ═══════════════════════════════════════════════════════════════════ */
  @media screen and (max-width: 479px) {
    .logotype {
      width: 8.1em;
      height: 1.45em;
    }

    .hamburger_link {
      font-size: 0.95em;
    }
  }

  /* ═══════════════════════════════════════════════════════════════════
     LINE-REVEAL — Desktop (pointer:fine)
     REPORT-001 § 4: transform 950ms, dimming de irmãos.
     Containers (> div) são template → scoped OK.
     .line-inner é criado por JS → usa :global()
     ═══════════════════════════════════════════════════════════════════ */
  @media (min-width: 992px) and (hover: hover) and (pointer: fine) {

    /* Container do texto: overflow oculta a linha duplicada */
    [data-line-reveal] > div,
    .button_primary .flex_button > div:first-child {
      position: relative;
      display: block;
      overflow: hidden;
      height: 1.25em;
      line-height: 1.25em;
    }

    /* Transição de opacidade dos links irmãos */
    .header [data-line-reveal] {
      transition: opacity 320ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* Dimming: quando qualquer link está em hover, irmãos ficam 65% */
    .header:has([data-line-reveal]:hover) [data-line-reveal] {
      opacity: 0.65;
    }

    .header:has([data-line-reveal]:hover) [data-line-reveal]:hover,
    .header:has([data-line-reveal]:hover) [data-line-reveal]:focus-visible {
      opacity: 1;
    }

    /* ── Arrow animation no CTA hover ── */
    .icon_arrow {
      position: relative;
      overflow: hidden;
    }

    .arrow_primary {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      opacity: 1;
      transition:
        transform 620ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity   620ms cubic-bezier(0.22, 1, 0.36, 1);
      z-index: 2;
    }

    .icon_arrow::after {
      content: "";
      position: absolute;
      left: 50%;
      top: 50%;
      width: 14px;
      height: 14px;
      background: url('/images/arrow-diagonal.svg') center / contain no-repeat;
      transform: translate(calc(-50% - 24px), calc(-50% + 24px));
      opacity: 0;
      transition:
        transform 620ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity   620ms cubic-bezier(0.22, 1, 0.36, 1);
      z-index: 1;
    }

    .button_primary:hover .arrow_primary,
    .button_primary:focus-visible .arrow_primary {
      transform: translate(calc(-50% + 24px), calc(-50% - 24px));
      opacity: 0;
    }

    .button_primary:hover .icon_arrow::after,
    .button_primary:focus-visible .icon_arrow::after {
      transform: translate(-50%, -50%);
      opacity: 1;
    }
  }
</style>

<!-- .line-inner é criado dinamicamente pelo JS — scoping Astro não alcança spans
     injetados. Usamos is:global apenas para as regras que afetam .line-inner. -->
<style is:global>
  @media (min-width: 992px) and (hover: hover) and (pointer: fine) {
    /* Span criado pelo JS de line-reveal */
    [data-line-reveal] .line-inner,
    .button_primary .flex_button > div:first-child .line-inner {
      position: relative;
      display: block;
      transform: translateY(0%);
      transition: transform 950ms cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
    }

    /* Linha duplicada exibida no hover (via ::after + data-text) */
    [data-line-reveal] .line-inner::after,
    .button_primary .flex_button > div:first-child .line-inner::after {
      content: attr(data-text);
      position: absolute;
      left: 0;
      top: 100%;
      white-space: nowrap;
    }

    /* Estado hover: desloca ambas as linhas para cima */
    [data-line-reveal]:hover .line-inner,
    [data-line-reveal]:focus-visible .line-inner,
    .button_primary:hover .flex_button > div:first-child .line-inner,
    .button_primary:focus-visible .flex_button > div:first-child .line-inner {
      transform: translateY(-100%);
    }
  }
</style>

<script>
  // ─── REPORT-001 § 4 — Comportamentos interativos do Header ──────────────────
  // 1. Detecção de scroll / is-light-section
  // 2. Line-reveal (wrapping DOM + animação CSS)
  // 3. Menu mobile (toggle + rota ativa)
  // ────────────────────────────────────────────────────────────────────────────

  (function initHeader() {

    // ── 1. SCROLL → is-light-section ─────────────────────────────────────────
    // Lógica fiel ao Header.jsx original: getBoundingClientRect no logotype,
    // verifica elementos sob o ponto via elementsFromPoint, usa rAF para throttle.
    function initScrollTheme() {
      const header = document.getElementById('site-header');
      const logo   = header?.querySelector('.svg_logo') as HTMLImageElement | null;
      if (!header || !logo) return;

      const logoWhite = logo.dataset.logoWhite ?? '';
      const logoBlue  = logo.dataset.logoBlue  ?? '';
      let   rafId     = 0;

      function updateTheme() {
        rafId = 0;

        // Apenas no desktop (> 991px), mesma condição do original
        if (!window.matchMedia('(min-width: 991px)').matches) {
          header.classList.remove('is-light-section');
          return;
        }

        const logotype = header.querySelector('.logotype');
        const rect     = (logotype ?? header).getBoundingClientRect();
        const x = Math.max(0, Math.min(window.innerWidth  - 1, rect.left + rect.width  / 2));
        const y = Math.max(0, Math.min(window.innerHeight - 1, rect.bottom + 8));

        const isLight = document
          .elementsFromPoint(x, y)
          .some((el) => {
            if (header.contains(el)) return false;
            return Boolean(
              el.closest('[data-section="light"], .light--theme, .cta_box, .is-light-section')
            );
          });

        header.classList.toggle('is-light-section', isLight);
        // Troca src da logo — data-logo-* definidos no HTML estático
        logo.src = isLight ? logoBlue : logoWhite;
      }

      function schedule() {
        if (rafId) return;
        rafId = requestAnimationFrame(updateTheme);
      }

      updateTheme();
      window.addEventListener('scroll', schedule, { passive: true });
      window.addEventListener('resize', schedule, { passive: true });
    }

    // ── 2. LINE-REVEAL ────────────────────────────────────────────────────────
    // Cria <span class="line-inner" data-text="…"> dentro de cada > div dos
    // links marcados com data-line-reveal. O CSS (is:global acima) cuida do
    // transform e do ::after com a linha duplicada.
    function initLineReveal() {
      const mq = window.matchMedia(
        '(min-width: 992px) and (hover: hover) and (pointer: fine)'
      );
      if (!mq.matches) return;

      const header = document.getElementById('site-header');
      if (!header) return;

      function wrapText(el: Element) {
        if (el.querySelector('.line-inner')) return; // já processado
        const text = (el.textContent ?? '').trim();
        if (!text) return;
        el.textContent = '';
        const span = document.createElement('span');
        span.className  = 'line-inner';
        span.dataset.text = text;
        span.textContent  = text;
        el.appendChild(span);
      }

      // Links com data-line-reveal
      header.querySelectorAll('[data-line-reveal] > div').forEach(wrapText);

      // Primeiro div do flex_button do CTA (texto "Entre em contato")
      header
        .querySelectorAll('.button_primary .flex_button > div:first-child')
        .forEach(wrapText);
    }

    // ── 3. MENU MOBILE ────────────────────────────────────────────────────────
    // Toggle: alterna .is-open no <button> e no <nav>; atualiza aria-expanded.
    // Rota ativa: compara pathname com href dos links, adiciona .w--current.
    // Fecha ao clicar em qualquer link do menu mobile.
    //
    // Nota: duração de entrada do mobile_menu não estava documentada no
    // REPORT-001 (a animação original usava apenas display:none → flex sem
    // transição). Mantemos o mesmo comportamento (sem transition de abertura)
    // para fidelidade ao original. Transição poderá ser adicionada depois.
    function initMobileMenu() {
      const btn  = document.getElementById('hamburger-btn')  as HTMLButtonElement | null;
      const menu = document.getElementById('mobile-navigation') as HTMLElement | null;
      if (!btn || !menu) return;

      // Toggle abrir/fechar
      btn.addEventListener('click', () => {
        const isOpen = btn.classList.toggle('is-open');
        menu.classList.toggle('is-open', isOpen);
        btn.setAttribute('aria-expanded', String(isOpen));
        menu.setAttribute('aria-hidden',  String(!isOpen));
      });

      // Fechar ao clicar em link interno
      menu.querySelectorAll('.mobile_link').forEach((link) => {
        link.addEventListener('click', () => {
          btn.classList.remove('is-open');
          menu.classList.remove('is-open');
          btn.setAttribute('aria-expanded', 'false');
          menu.setAttribute('aria-hidden',  'true');
        });
      });

      // Marcar link ativo pela rota atual
      const currentPath = window.location.pathname.replace(/\/+$/, '') || '/';
      menu.querySelectorAll<HTMLAnchorElement>('.mobile_link').forEach((link) => {
        // Ignora fragmento (#section) na comparação
        const linkPath = (link.getAttribute('href') ?? '')
          .split('#')[0]
          .replace(/\/+$/, '') || '/';
        if (linkPath === currentPath) {
          link.classList.add('w--current');
        }
      });
    }

    // ── Init ─────────────────────────────────────────────────────────────────
    initScrollTheme();
    initLineReveal();
    initMobileMenu();

  })();
</script>
