---
/**
 * src/components/BlogCTA.astro
 * Bloco de CTA azul Off-Data para o final de cada post do blog.
 * Renderizado automaticamente pelo [slug].astro — não precisa ser
 * inserido manualmente nos arquivos MDX.
 */

const WHATSAPP_NUMBER = '5534992362596';
const MESSAGE = encodeURIComponent(
  'Olá! Li o blog da Off-Data e quero um diagnóstico gratuito da minha presença digital.'
);
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${MESSAGE}`;
---

<section class="blog-cta" aria-labelledby="blog-cta-heading">
  <div class="blog-cta-inner">
    <div class="blog-cta-text">
      <h2 id="blog-cta-heading" class="blog-cta-title">
        Seu site está preparado para converter?
      </h2>
      <p class="blog-cta-subtitle">
        A Off-Data faz um diagnóstico gratuito da sua presença digital em Uberlândia.
      </p>
    </div>
    <a
      href={WHATSAPP_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="blog-cta-btn"
      aria-label="Solicitar diagnóstico gratuito via WhatsApp"
    >
      Quero meu diagnóstico gratuito →
    </a>
  </div>
</section>

<style>
  .blog-cta {
    margin: 3.5rem 0 0;
    border-radius: 16px;
    background: #044AB3;
    overflow: hidden;
  }

  .blog-cta-inner {
    padding: 2.5rem 2.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .blog-cta-text {
    flex: 1;
    min-width: 220px;
  }

  .blog-cta-title {
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.65rem);
    font-weight: 600;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 0.6rem;
  }

  .blog-cta-subtitle {
    font-size: 0.95rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.55;
    margin: 0;
  }

  .blog-cta-btn {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    background: #ffffff;
    color: #044AB3;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    padding: 0.85em 1.5em;
    border-radius: 999px;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
    flex-shrink: 0;
  }

  .blog-cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
    background: #f0f4ff;
  }

  .blog-cta-btn:active {
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .blog-cta-inner {
      padding: 2rem 1.5rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .blog-cta-btn {
      width: 100%;
      justify-content: center;
      font-size: 0.95rem;
      padding: 0.9em 1.5em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-cta-btn { transition: none; }
  }
</style>
