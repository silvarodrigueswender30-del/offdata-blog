---
/**
 * src/components/SegmentBeforeAfter.astro — v3
 * Comparação visual "Site Fraco vs. Site Profissional"
 * Utiliza withBase() para garantir carregamento correto sob a subpasta /blog/
 */
import { withBase } from '../utils/withBase';

interface Props {
  segmentLabel?: string;
  badImage?: string;     // path /images/... da imagem "ruim"
  goodImage?: string;    // path /images/... da imagem "boa" (segmento)
  badAlt?: string;
  goodAlt?: string;
}

const {
  segmentLabel = '',
  badImage  = '/images/before-after/before-after-bad.jpg',
  goodImage = '/images/before-after/before-after-advogados.jpg',
  badAlt    = 'Computador antigo representando site fraco e desatualizado',
  goodAlt   = 'Ambiente de trabalho moderno representando site profissional',
} = Astro.props;

const badImgUrl  = withBase(badImage);
const goodImgUrl = withBase(goodImage);
---

<section class="sba" aria-labelledby="sba-heading">
  <div class="sba__inner">

    <div class="sba__header">
      <span class="sba__tag">Comparação real</span>
      <h2 id="sba-heading" class="sba__title">
        Site fraco vs. site profissional{segmentLabel ? ` ${segmentLabel}` : ''}
      </h2>
      <p class="sba__sub">
        A diferença entre um site genérico e um site da Off-Data vai muito além da estética — ela aparece direto no faturamento.
      </p>
    </div>

    <div class="sba__columns">

      <!-- ══ COLUNA ANTES ══ -->
      <div class="sba__col sba__col--bad">
        <div class="sba__col-badge sba__col-badge--bad">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
            <path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          Site Fraco / Genérico
        </div>

        <!-- Imagem "antes" com overlay de tela genérica -->
        <div class="sba__img-wrap sba__img-wrap--bad">
          <img
            src={badImgUrl}
            alt={badAlt}
            class="sba__img"
            loading="lazy"
            decoding="async"
            width="520"
            height="260"
          />
          <!-- HUD de "site ruim" sobreposto -->
          <div class="sba__overlay sba__overlay--bad" aria-hidden="true">
            <div class="sba__hud-bar sba__hud-bar--bad">
              <span class="sba__hud-dot"></span>
              <span class="sba__hud-dot"></span>
              <span class="sba__hud-dot"></span>
              <div class="sba__hud-url sba__hud-url--bad">meusite.com.br</div>
            </div>
            <div class="sba__hud-pills">
              <span class="sba__pill sba__pill--red">⚠ Lento: 8.4s</span>
              <span class="sba__pill sba__pill--red">⚠ Fora do Google</span>
            </div>
          </div>
        </div>

        <ul class="sba__list sba__list--bad">
          <li>
            <span class="sba__icon sba__icon--x">✕</span>
            <div>
              <strong>Carregamento lento (+6s)</strong>
              <span>Google penaliza e o visitante abandona antes de ver o produto</span>
            </div>
          </li>
          <li>
            <span class="sba__icon sba__icon--x">✕</span>
            <div>
              <strong>Invisível no Google</strong>
              <span>Sem SEO local — não aparece para buscas do segmento em Uberlândia</span>
            </div>
          </li>
          <li>
            <span class="sba__icon sba__icon--x">✕</span>
            <div>
              <strong>Design genérico</strong>
              <span>Template ultrapassado que não transmite autoridade nem confiança</span>
            </div>
          </li>
          <li>
            <span class="sba__icon sba__icon--x">✕</span>
            <div>
              <strong>Quebrado no celular</strong>
              <span>Mais de 70% dos acessos são mobile — e o layout não funciona</span>
            </div>
          </li>
          <li>
            <span class="sba__icon sba__icon--x">✕</span>
            <div>
              <strong>Sem CTA estratégico</strong>
              <span>Visitante não sabe o próximo passo — sai sem converter</span>
            </div>
          </li>
        </ul>

        <div class="sba__verdict sba__verdict--bad">
          Perde clientes para o concorrente todos os dias
        </div>
      </div>

      <!-- Divisor VS -->
      <div class="sba__vs" aria-hidden="true">VS</div>

      <!-- ══ COLUNA DEPOIS ══ -->
      <div class="sba__col sba__col--good">
        <div class="sba__col-badge sba__col-badge--good">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
            <path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Site Profissional Off-Data
        </div>

        <!-- Imagem "depois" com overlay premium -->
        <div class="sba__img-wrap sba__img-wrap--good">
          <img
            src={goodImgUrl}
            alt={goodAlt}
            class="sba__img"
            loading="lazy"
            decoding="async"
            width="520"
            height="260"
          />
          <!-- HUD de "site profissional" sobreposto -->
          <div class="sba__overlay sba__overlay--good" aria-hidden="true">
            <div class="sba__hud-bar sba__hud-bar--good">
              <span class="sba__hud-dot sba__hud-dot--good"></span>
              <span class="sba__hud-dot sba__hud-dot--good"></span>
              <span class="sba__hud-dot sba__hud-dot--good"></span>
              <div class="sba__hud-url sba__hud-url--good">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" style="flex-shrink:0">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="currentColor"/>
                </svg>
                offdata.digital/seu-site
              </div>
            </div>
            <div class="sba__hud-pills">
              <span class="sba__pill sba__pill--blue">✓ &lt;1.8s — Google: 98</span>
              <span class="sba__pill sba__pill--blue">✓ Página 1</span>
            </div>
          </div>
        </div>

        <ul class="sba__list sba__list--good">
          <li>
            <span class="sba__icon sba__icon--check">✓</span>
            <div>
              <strong>Carregamento &lt;2 segundos</strong>
              <span>Core Web Vitals aprovado — Google favorece e o cliente fica</span>
            </div>
          </li>
          <li>
            <span class="sba__icon sba__icon--check">✓</span>
            <div>
              <strong>Página 1 do Google</strong>
              <span>SEO local estruturado para Uberlândia e Triângulo Mineiro</span>
            </div>
          </li>
          <li>
            <span class="sba__icon sba__icon--check">✓</span>
            <div>
              <strong>Design de autoridade</strong>
              <span>Credibilidade e posicionamento premium desde o primeiro acesso</span>
            </div>
          </li>
          <li>
            <span class="sba__icon sba__icon--check">✓</span>
            <div>
              <strong>100% responsivo</strong>
              <span>Experiência impecável em celular, tablet e desktop</span>
            </div>
          </li>
          <li>
            <span class="sba__icon sba__icon--check">✓</span>
            <div>
              <strong>CTA estratégico em cada seção</strong>
              <span>Visitante guiado até o contato pelo WhatsApp em segundos</span>
            </div>
          </li>
        </ul>

        <div class="sba__verdict sba__verdict--good">
          Gera leads qualificados enquanto você trabalha
        </div>
      </div>

    </div><!-- /.sba__columns -->
  </div>
</section>

<style>
  .sba {
    width: calc(100% + 3.5rem);
    margin-left: -1.75rem;
    margin-right: -1.75rem;
    background: #f4f6fb;
    padding: 4rem 0 5rem;
    margin-top: 3.5rem;
    margin-bottom: 3.5rem;
  }

  .sba__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.75rem;
  }

  /* ── Header ── */
  .sba__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .sba__tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--blue, #044AB3);
    background: rgba(4, 74, 179, 0.08);
    padding: 0.35em 0.9em;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  .sba__title {
    font-size: clamp(1.8rem, 3.2vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: #151515;
    margin: 0 0 0.75rem;
  }

  .sba__sub {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(21, 21, 21, 0.72);
    max-width: 52ch;
    margin: 0 auto;
  }

  /* ── Grid 2 colunas + VS ── */
  .sba__columns {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .sba__vs {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: #151515;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-top: 4.5rem;
    flex-shrink: 0;
  }

  /* ── Colunas ── */
  .sba__col {
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    overflow: hidden;
  }

  .sba__col--bad  { border: 1.5px solid rgba(220,38,38,0.2); box-shadow: 0 2px 24px rgba(220,38,38,0.06); }
  .sba__col--good { border: 1.5px solid rgba(4,74,179,0.2);  box-shadow: 0 4px 32px rgba(4,74,179,0.1); }

  /* ── Badge de cabeçalho ── */
  .sba__col-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.4em 0.85em;
    border-radius: 6px;
    align-self: flex-start;
  }

  .sba__col-badge--bad  { background: rgba(220,38,38,0.08); color: #dc2626; }
  .sba__col-badge--good { background: rgba(4,74,179,0.08);  color: var(--blue, #044AB3); }

  /* ══ IMAGENS COM OVERLAY ══ */
  .sba__img-wrap {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 16 / 8;
  }

  .sba__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Filtros visuais para reforçar o "antes/depois" */
  .sba__img-wrap--bad  .sba__img { filter: saturate(0.3) brightness(0.85) contrast(0.9); }
  .sba__img-wrap--good .sba__img { filter: saturate(1.05) brightness(1.0); }

  /* Gradiente de escurecer a base para o HUD */
  .sba__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0.6rem;
  }

  .sba__overlay--bad  { background: linear-gradient(180deg, rgba(0,0,0,0.45) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.5) 100%); }
  .sba__overlay--good { background: linear-gradient(180deg, rgba(4,20,60,0.55) 0%, transparent 45%, transparent 55%, rgba(4,20,60,0.55) 100%); }

  /* ── Barra de endereço falsa ── */
  .sba__hud-bar {
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 5px;
    padding: 0.3rem 0.6rem;
    width: 100%;
  }

  .sba__hud-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    flex-shrink: 0;
  }

  .sba__hud-dot--good { background: rgba(100,200,100,0.7); }

  .sba__hud-url {
    flex: 1;
    margin-left: 0.4rem;
    font-size: 0.62rem;
    display: flex;
    align-items: center;
    gap: 0.3em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sba__hud-url--bad  { color: rgba(255,255,255,0.55); font-style: italic; }
  .sba__hud-url--good { color: rgba(255,255,255,0.92); font-weight: 500; }

  /* ── Pills de status ── */
  .sba__hud-pills {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .sba__pill {
    font-size: 0.6rem;
    font-weight: 600;
    padding: 0.25em 0.6em;
    border-radius: 100px;
    white-space: nowrap;
  }

  .sba__pill--red  { background: rgba(220,38,38,0.85);  color: #fff; }
  .sba__pill--blue { background: rgba(4,74,179,0.9);     color: #fff; }

  /* ══ LISTAS ══ */
  .sba__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sba__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .sba__list li div {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
  }

  .sba__list strong {
    font-size: 0.86rem;
    font-weight: 600;
    color: #151515;
    line-height: 1.3;
  }

  .sba__list span {
    font-size: 0.76rem;
    line-height: 1.5;
    color: rgba(21, 21, 21, 0.68);
  }

  .sba__icon {
    width: 1.35rem;
    height: 1.35rem;
    min-width: 1.35rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .sba__icon--x     { background: rgba(220,38,38,0.1); color: #dc2626; }
  .sba__icon--check { background: rgba(4,74,179,0.1);  color: var(--blue, #044AB3); }

  /* ══ VEREDICTO ══ */
  .sba__verdict {
    font-size: 0.82rem;
    font-weight: 600;
    text-align: center;
    padding: 0.7rem 1rem;
    border-radius: 6px;
    letter-spacing: -0.01em;
  }

  .sba__verdict--bad  { background: rgba(220,38,38,0.06); color: #dc2626; border: 1px solid rgba(220,38,38,0.15); }
  .sba__verdict--good { background: rgba(4,74,179,0.06);  color: var(--blue, #044AB3); border: 1px solid rgba(4,74,179,0.15); }

  /* ══ RESPONSIVE ══ */
  @media (max-width: 768px) {
    .sba__columns {
      grid-template-columns: 1fr;
    }
    .sba__vs { display: none; }
  }
</style>
