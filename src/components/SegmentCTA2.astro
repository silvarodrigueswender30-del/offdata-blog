---
/**
 * src/components/SegmentCTA2.astro
 * Bloco CTA final escuro — inspirado no CtaBoxSection do site institucional.
 * Substitui o BlogCTA genérico nas páginas de segmento.
 *
 * Props:
 *   heading  — título do bloco (padrão genérico se omitido)
 *   sub      — subtítulo/descrição
 *   segment  — nome do segmento para personalizar o CTA (ex: "advocacia")
 */

interface Props {
  heading?: string;
  sub?: string;
  segment?: string;
}

const {
  heading = 'Pronto para ter um site que trabalha para o seu negócio?',
  sub = 'Fale com a Off-Data hoje e receba um diagnóstico gratuito da sua presença digital.',
  segment,
} = Astro.props;

const WHATSAPP_NUMBER = '5534992362596';
const msgBase = segment
  ? `Olá! Vi o artigo sobre sites para ${segment} no blog da Off-Data e gostaria de um diagnóstico gratuito.`
  : 'Olá! Vim pelo blog da Off-Data e gostaria de conversar sobre minha presença digital.';
const WA_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msgBase)}`;
---

<section class="segment-cta2" aria-labelledby="cta2-heading">
  <!-- decoração de fundo -->
  <div class="cta2-bg-blur" aria-hidden="true"></div>

  <div class="cta2-inner">
    <div class="cta2-label">Off-Data Engenharia Digital</div>
    <h2 id="cta2-heading" class="cta2-heading">{heading}</h2>
    <p class="cta2-sub">{sub}</p>
    <div class="cta2-actions">
      <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="cta2-btn-primary">
        Falar no WhatsApp
      </a>
      <a href="https://www.offdata.digital/" class="cta2-btn-secondary">
        Conhecer a Off-Data →
      </a>
    </div>
  </div>
</section>

<style>
  .segment-cta2 {
    position: relative;
    background: var(--blue, #044AB3);
    border-radius: 20px;
    overflow: hidden;
    margin: 4rem 0 2rem;
    padding: 4rem 3rem;
    text-align: center;
    isolation: isolate;
  }

  .cta2-bg-blur {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 20% 30%, rgba(255,255,255,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 80% 70%, rgba(0,0,0,0.12) 0%, transparent 60%);
    z-index: 0;
    pointer-events: none;
  }

  .cta2-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta2-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .cta2-heading {
    font-size: clamp(1.6rem, 3vw + 0.5rem, 2.6rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
  }

  .cta2-sub {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    max-width: 480px;
  }

  .cta2-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .cta2-btn-primary {
    background: #fff;
    color: var(--blue, #044AB3);
    padding: 0.875em 2em;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.22s ease, box-shadow 0.22s ease, opacity 0.22s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }

  .cta2-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.28);
    opacity: 0.95;
  }

  .cta2-btn-secondary {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    padding: 0.875em 1.25em;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.25);
    transition: background 0.22s ease, border-color 0.22s ease, transform 0.22s ease;
  }

  .cta2-btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.45);
    transform: translateY(-2px);
    color: #fff;
  }

  @media (max-width: 767px) {
    .segment-cta2 {
      padding: 3rem 1.5rem;
      border-radius: 14px;
    }

    .cta2-actions {
      flex-direction: column;
      width: 100%;
    }

    .cta2-btn-primary,
    .cta2-btn-secondary {
      width: 100%;
      text-align: center;
      justify-content: center;
      display: inline-flex;
    }
  }
</style>
