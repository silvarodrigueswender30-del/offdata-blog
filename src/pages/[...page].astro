---
/**
 * src/pages/[...page].astro — Páginas 2, 3, … da listagem do blog.
 * Página 1 é servida por src/pages/index.astro (mesmo layout).
 *
 * Com base: '/blog', as URLs geradas são:
 *   /blog/2, /blog/3, etc.
 *
 * Nota de arquitetura:
 *   O usuário solicitou src/pages/blog/[...page].astro, mas com base: '/blog'
 *   aquela localização geraria /blog/blog/2 (caminho duplicado). A localização
 *   correta para servir /blog/2 é src/pages/[...page].astro.
 */
import { getCollection }   from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPathsOptions, Page } from 'astro';
import BaseLayout          from '../layouts/BaseLayout.astro';
import Header              from '../components/Header.astro';
import Footer              from '../components/Footer.astro';
import PostCard            from '../components/PostCard.astro';
import { getReadingTime }  from '../utils/readingTime';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const allPosts = (
    await getCollection('posts', ({ data }) => data.draft === false)
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  // Gera todas as páginas com paginate(), depois filtra para retornar
  // apenas as páginas 2+ (página 1 é gerenciada por index.astro).
  const allPages = paginate(allPosts, { pageSize: 12 });
  return allPages.filter(({ props }) => (props as { page: Page<CollectionEntry<'posts'>> }).page.currentPage > 1);
}

interface Props {
  page: Page<CollectionEntry<'posts'>>;
}

const { page } = Astro.props;
const totalPages   = page.lastPage;
const currentPage  = page.currentPage;
const isEmpty      = page.data.length === 0;

// URLs de navegação fornecidas pelo objeto page do Astro
const prevUrl = page.url.prev ?? null;
const nextUrl = page.url.next ?? null;

// Meta SEO
const canonicalUrl = `https://www.offdata.digital/blog/${currentPage}`;
---

<BaseLayout>
  <Fragment slot="head">
    <title>Blog — Off-Data | Página {currentPage}</title>
    <meta
      name="description"
      content={`Artigos técnicos sobre SEO, performance web, tráfego pago e estratégia digital. Página ${currentPage} de ${totalPages}.`}
    />
    {/* Páginas internas do índice não precisam ser indexadas individualmente */}
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={canonicalUrl} />
    {prevUrl && <link rel="prev" href={`https://www.offdata.digital${prevUrl}`} />}
    {nextUrl && <link rel="next" href={`https://www.offdata.digital${nextUrl}`} />}
  </Fragment>

  <Header />

  <main id="blog-main" class="blog-main" data-section="light">
    <div class="blog-container">

      <!-- ── Cabeçalho da seção ── -->
      <header class="blog-header">
        <h1 class="blog-title">Blog</h1>
        <p class="blog-subtitle">
          Conteúdo técnico para empresas que levam posicionamento digital a sério.
        </p>
      </header>

      <!-- ── Grid de posts ── -->
      {isEmpty ? (
        <div class="empty-state" role="status">
          <p>Novos conteúdos em breve.</p>
        </div>
      ) : (
        <section class="posts-grid" aria-label={`Lista de artigos — página ${currentPage}`}>
          {page.data.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              coverImage={post.data.coverImage}
              coverImageAlt={post.data.coverImageAlt}
              slug={post.id}
              readingTime={getReadingTime(post.body ?? '')}
              priority={false}
            />
          ))}
        </section>
      )}

      <!-- ── Paginação ── -->
      {!isEmpty && (
        <nav class="pagination" aria-label="Navegação entre páginas do blog">
          {prevUrl ? (
            <a href={prevUrl} class="pagination-btn pagination-prev" rel="prev">
              <span class="btn-arrow" aria-hidden="true">←</span>
              Anterior
            </a>
          ) : (
            <span class="pagination-slot" aria-hidden="true" />
          )}

          <span class="pagination-info">
            Página {currentPage} de {totalPages}
          </span>

          {nextUrl ? (
            <a href={nextUrl} class="pagination-btn pagination-next" rel="next">
              Próxima
              <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
          ) : (
            <span class="pagination-slot" aria-hidden="true" />
          )}
        </nav>
      )}

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Layout ── */
  .blog-main {
    min-height: 100svh;
    padding-top: 6rem;
    background-color: var(--white);
  }

  .blog-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 1.75rem 5rem;
  }

  /* ── Cabeçalho ── */
  .blog-header {
    margin-bottom: 3rem;
  }

  .blog-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 500;
    line-height: 1;
    color: var(--black);
    letter-spacing: -.02em;
    margin-bottom: .5em;
  }

  .blog-subtitle {
    font-size: clamp(.9rem, 2vw, 1.05rem);
    font-weight: 400;
    line-height: 1.5;
    color: rgba(0, 0, 0, .55);
    max-width: 42ch;
  }

  /* ── Grid ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Estado vazio ── */
  .empty-state {
    text-align: center;
    padding: 5rem 0;
    color: rgba(0, 0, 0, .5);
    font-size: 1.1rem;
    font-weight: 500;
  }

  /* ── Paginação ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0, 0, 0, .1);
    gap: 1rem;
  }

  .pagination-slot {
    width: 8rem;
    flex-shrink: 0;
  }

  .pagination-info {
    font-size: .85rem;
    font-weight: 500;
    color: rgba(0, 0, 0, .45);
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: .5em;
    background: var(--blue);
    color: var(--white);
    font-size: .85rem;
    font-weight: 500;
    padding: .6em 1.25em;
    border-radius: .25em;
    text-decoration: none;
    transition: opacity 250ms ease;
    white-space: nowrap;
    min-width: 8rem;
  }

  .pagination-btn:hover {
    opacity: .85;
  }

  .pagination-prev {
    justify-content: flex-start;
  }

  .pagination-next {
    justify-content: flex-end;
  }

  .btn-arrow {
    font-size: 1em;
    line-height: 1;
  }

  /* ── Responsivo: 2 colunas (991px) ── */
  @media (max-width: 991px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .blog-container {
      padding: 2.5rem 1.25rem 4rem;
    }
  }

  /* ── Responsivo: 1 coluna (767px) ── */
  @media (max-width: 767px) {
    .blog-main {
      padding-top: 5rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .blog-container {
      padding: 2rem 1rem 3rem;
    }

    .pagination-slot {
      display: none;
    }
  }
</style>
