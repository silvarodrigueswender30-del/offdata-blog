---
/**
 * src/pages/index.astro — Página 1 da listagem do blog.
 * Páginas 2, 3… são geradas por src/pages/[...page].astro.
 *
 * Com base: '/blog', esta página serve em: www.offdata.digital/blog/
 */
import { getCollection } from 'astro:content';
import BaseLayout      from '../layouts/BaseLayout.astro';
import Header          from '../components/Header.astro';
import Footer          from '../components/Footer.astro';
import PostCard        from '../components/PostCard.astro';
import { getReadingTime } from '../utils/readingTime';

const PAGE_SIZE = 12;

const allPosts = (
  await getCollection('posts', ({ data }) => data.draft === false)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts        = allPosts.slice(0, PAGE_SIZE);
const totalPages   = Math.ceil(allPosts.length / PAGE_SIZE);
const hasNextPage  = totalPages > 1;
const isEmpty      = allPosts.length === 0;

const prevUrl: string | null = null;                     // página 1: sem anterior
const nextUrl: string | null = hasNextPage ? '/blog/2' : null;
---

<BaseLayout>
  <Fragment slot="head">
    <title>Blog — Off-Data Engenharia Digital</title>
    <meta
      name="description"
      content="Artigos técnicos sobre SEO, performance web, tráfego pago e estratégia digital para empresas premium em Uberlândia e Triângulo Mineiro."
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.offdata.digital/blog/" />
    {hasNextPage && <link rel="next" href={`https://www.offdata.digital/blog/2`} />}
  </Fragment>

  <Header />

  <main id="blog-main" class="blog-main" data-section="light">
    <div class="blog-container">

      <!-- ── Cabeçalho da seção ── -->
      <header class="blog-header">
        <h1 class="blog-title">Blog</h1>
        <p class="blog-subtitle">
          Conteúdo técnico para empresas que levam posicionamento digital a sério.
        </p>
      </header>

      <!-- ── Grid de posts ── -->
      {isEmpty ? (
        <div class="empty-state" role="status">
          <p>Novos conteúdos em breve.</p>
        </div>
      ) : (
        <section class="posts-grid" aria-label="Lista de artigos">
          {posts.map((post, index) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              coverImage={post.data.coverImage}
              coverImageAlt={post.data.coverImageAlt}
              slug={post.id}
              readingTime={getReadingTime(post.body ?? '')}
              priority={index === 0}
            />
          ))}
        </section>
      )}

      <!-- ── Paginação ── -->
      {!isEmpty && totalPages > 1 && (
        <nav class="pagination" aria-label="Navegação entre páginas do blog">
          <span class="pagination-slot pagination-prev" aria-hidden="true" />

          <span class="pagination-info">
            Página 1 de {totalPages}
          </span>

          {nextUrl && (
            <a href={nextUrl} class="pagination-btn pagination-next" rel="next">
              Próxima
              <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
          )}
        </nav>
      )}

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Layout ── */
  .blog-main {
    min-height: 100svh;
    padding-top: 6rem; /* compensa o header fixo */
    background-color: var(--white);
  }

  .blog-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 1.75rem 5rem;
  }

  /* ── Cabeçalho ── */
  .blog-header {
    margin-bottom: 3rem;
  }

  .blog-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 500;
    line-height: 1;
    color: var(--black);
    letter-spacing: -.02em;
    margin-bottom: .5em;
  }

  .blog-subtitle {
    font-size: clamp(.9rem, 2vw, 1.05rem);
    font-weight: 400;
    line-height: 1.5;
    color: rgba(0, 0, 0, .55);
    max-width: 42ch;
  }

  /* ── Grid ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Estado vazio ── */
  .empty-state {
    text-align: center;
    padding: 5rem 0;
    color: rgba(0, 0, 0, .5);
    font-size: 1.1rem;
    font-weight: 500;
  }

  /* ── Paginação ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0, 0, 0, .1);
    gap: 1rem;
  }

  .pagination-slot {
    width: 8rem; /* espelho do botão para manter o texto centrado */
    flex-shrink: 0;
  }

  .pagination-info {
    font-size: .85rem;
    font-weight: 500;
    color: rgba(0, 0, 0, .65);
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: .5em;
    background: var(--blue);
    color: var(--white);
    font-size: .85rem;
    font-weight: 500;
    padding: .6em 1.25em;
    border-radius: .25em;
    text-decoration: none;
    transition: opacity 250ms ease;
    white-space: nowrap;
  }

  .pagination-btn:hover {
    opacity: .85;
  }

  .btn-arrow {
    font-size: 1em;
    line-height: 1;
  }

  /* ── Responsivo: 2 colunas (991px) ── */
  @media (max-width: 991px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .blog-container {
      padding: 2.5rem 1.25rem 4rem;
    }
  }

  /* ── Responsivo: 1 coluna (767px) ── */
  @media (max-width: 767px) {
    .blog-main {
      padding-top: 5rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .blog-container {
      padding: 2rem 1rem 3rem;
    }

    .blog-title {
      margin-bottom: .4em;
    }

    .pagination-slot {
      display: none;
    }
  }
</style>
